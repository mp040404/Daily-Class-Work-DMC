package com.example.demo.entities;

import java.sql.Date;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@NoArgsConstructor
@AllArgsConstructor
@Data
public class User {

	id | name  | password | email           | birth      | addr        | role
	
	private int id;
	private String name;
	private String password;
	private String email;
	private Date birth;
	private String addr;
	private int role = 0;
	
