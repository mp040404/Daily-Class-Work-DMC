package com.example.demo.dao;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Repository;

import com.example.demo.entities.Book;

@import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Repository;

@Repository
public class BookDaoImpl implements BookDao {

    @Autowired
    private JdbcTemplate jdbcTemplate;

    @Autowired
    private BookRowMapping bookRowMapping;

    // 🔹 Get all books
    @Override
    public List<Book> findAll() {
        String sql = "SELECT * FROM books";
        return jdbcTemplate.query(sql, bookRowMapping);
    }

    // 🔹 Insert book
    @Override
    public int save(Book b) {
        String sql = "INSERT INTO books (id, name, author, subject, price) VALUES (?, ?, ?, ?, ?)";
        return jdbcTemplate.update(sql,
                b.getId(),
                b.getName(),
                b.getAuthor(),
                b.getSubject(),
                b.getPrice());
    }

    // 🔹 Get books by subject (✅ FIXED)
    @Override
    public List<Book> findBySubject(String subject) {
        String sql = "SELECT * FROM books WHERE LOWER(subject) = LOWER(?)";
        return jdbcTemplate.query(sql, bookRowMapping, subject);
    }
}
