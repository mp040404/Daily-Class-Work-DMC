package com.example.demo.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;
import com.example.demo.Rest01Application;
import com.example.demo.daos.BookDao;
import com.example.demo.entities.Book;

@RequestMapping("/v1")
@RestController
public class BookRestControllerV1 {

    private final Rest01Application rest01Application;
	
	@Autowired
	private BookDao bookDao;

    BookRestControllerV1(Rest01Application rest01Application) {
        this.rest01Application = rest01Application;
    }
	
	@GetMapping("/books")
	public List<Book> getAllBook(){
		List<Book> list = bookDao.FindAll();
		return list;
				
	}
	
	@GetMapping("/books/{id}")
	public Book getBookId(@PathVariable("id") int bookId) {
		Book b = bookDao.findById(bookId);
		if(b == null)
			return null;
		return b;
	}
	
	@PostMapping("/books")
	public int addBook(@RequestBody Book b) {
		try
		{
			int cnt = bookDao.save(b);
			return cnt;
		}catch (Exception e) {
			e.printStackTrace();
			return 0;
		}
	}
	
	@PutMapping("/books/{id}")
	public int updateBook(@PathVariable("id") int bookId , @RequestBody Book b) {
		try {
			b.setId(bookId);
			int cnt = bookDao.update(b);
			return cnt;
		}catch (Exception e) {
			e.printStackTrace();
			return 0;
		}
		
	}
	

}
