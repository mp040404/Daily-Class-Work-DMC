package com.example.demo;


import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.transaction.annotation.Transactional;



public interface BookDao extends JpaRepository<Book, Integer> {
	
	List<Book> findByAuthor(String author);
	List<Book> findByCategoryOrderByPriceDesc(String category);
	List<Book> findById(int id);
	List<Book> findByPriceBetween(double minPrice,double maxPrice);
	
	//update operation .... increase price with persentage
	@Transactional
	@Modifying
	@Query("update Book b set b.price=b.price*?1 where b.category=?2")
	int incBookPriceByCategory(double incPrice , String category);
	//get all Category
	@Query(value="Select Distinct subject from books",nativeQuery = true)//sql quary
	List<String> findUniqueCategories();
	
	//delete operation .... delete all of book of givent category
	@Transactional
	@Modifying
	@Query("Delete from book b  where b.category =:p_category")
	int deleteBookByCategory(@Param("p_category") String category);
	
}
