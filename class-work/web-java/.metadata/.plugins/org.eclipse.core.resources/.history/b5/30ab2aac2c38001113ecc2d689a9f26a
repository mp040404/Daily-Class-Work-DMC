package com.example.demo;

import java.awt.event.ComponentListener;
import java.util.Optional;
import java.util.Scanner;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.CommandLineRunner;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;

@SpringBootApplication
public class Sb12jparelnApplication implements CommandLineRunner {

	public static void main(String[] args) {
		SpringApplication.run(Sb12jparelnApplication.class, args);
	}
	@Autowired
	private DeptDao deptDao;
	
	@Autowired
	private EmpDao empDao;
	
 	@Override
	public void run(String... args) throws Exception {
		Scanner sc= new Scanner(System.in);
		
		//**********************************************************
		System.out.println("Enter Dept id you want to find it");
		int cnt =sc.nextInt();
		Optional<Dept> od = deptDao.findById(cnt);
		if(od.isPresent()) {
			Dept d = od.get();
			System.out.println(d);
		}else {
			System.out.println("Dept not found ....!");
		}
		
		
	}

	
}
