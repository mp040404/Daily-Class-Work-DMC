	private void addRec(Node root, int val) {
		Node trav = root ;
		if(trav == null) {
			trav = root;
		}
		if(trav.left == null || val < trav.data) {
			addRec(trav.left,val);
		}
		if(trav.right == null || val > trav.data)
		{
			addRec(trav.right, val);
		}
		
	
}

	
	
