package SinglyLinearLinkedList;

public class main {
	
	public static void main(String[] args) {
		
		SinglyLinearLinkedList list = new SinglyLinearLinkedList();
		
		System.out.println("addFirst() : ");
		list.addFirst(66);
		list.addFirst(55);
		list.addFirst(78);
		list.displayList();
		
		System.out.println("addLast() : ");
		list.addLast(90);
		list.addLast(88);
		list.displayList();
		
		System.out.println("addAtPosition() : ");
		list.addAtPosition(70, -2);
		list.displayList();
		list.addAtPosition(95, 100);
		list.displayList();
		
		System.out.println("\n delFirst() : ");
		list.delFirst();
		list.displayList();
		
		System.out.println("\n delLast() : ");
		list.delLast();
		list.displayList(); 
		
		list.delAtPosition(1);
		list.displayList();
		
		list.delAtPosition(3);
		list.displayList(); 
		
		
	}

}
