class TaskNode {
	
	int taskid;
	String taskName;
	TaskNode next ,prev;
	

	public TaskNode(int taskid, String taskName) {
		super();
		this.taskid = taskid;
		this.taskName = taskName;
		next = prev = null;
		
	}
	
}

