	public Node search(int val) {
		return searchRec(root , val);
		
	}
	
	private Node searchRec(Node root, int val) {
		Node trav = root ;
		if(trav == null || trav.data == val) {
			return trav;
		}
		if(val < trav.data) {
			return searchRec(trav.left, val);
		}
		if(val > trav.data)
		{
			return searchRec(trav.right, val);
		}
		
	return trav;
}

	public Node[] searchWithParent(int val) {
		Node trav = root;
		Node parent = null ;
		
		while(trav != null) {
			if (val == trav.data) 
				return new Node[] {
						trav,parent };
				parent = trav ;
				if(val < trav.data)
					trav = trav.left;
				else
					trav = trav.right;
				}
				return new Node[] { null , null } ;
			}
		
	void delete(int val) {
		Node[] find = searchWithParent(val);
		Node temp = find[0] , parent = find[1];
		if(temp == null) {
			System.out.println("Node Not Found");
			return;
		}
		
		if(temp.left != null && temp.right != null) {
			parent = temp;
			Node succ = temp.right;
			while(succ.left != null) {
				parent = succ ;
				succ = succ.left ;
			}
			temp.data = succ.data;
			temp = succ;
		}
		if(temp.left == null) {
			if(temp == root) {
				root = temp.right ;
			}else if(temp == parent.left) {
				parent.left = temp.right;
			}else {
				parent.right = temp.right;
			}
		}
		else if(temp.right == null){
			if(temp == root) {
				root = temp.left;
			}else if(temp == parent.left){
				parent.left = temp.left ;
			}else {
				parent.right = temp.left;
			}
		}
	}
	
	private int height(Node trav) {
		if(trav == null) {
			return -1;
		}
		int lh = height(trav.left);
		int rh = height(trav.right);
		int ht = Integer.max(lh, rh)+1;
		
		return ht;
	}
	
	public int height() {
		int ht = height(root);
		return ht;
	}
	
	
