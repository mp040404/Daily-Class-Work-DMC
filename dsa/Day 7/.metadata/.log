		System.out.println();
	}

	private void postorder(Node trav) {
		if(trav == null)
			return ;
		postorder(trav.left);
		postorder(trav.right);
		System.out.print(trav.data + " , ");
	}
	
	public void postorder() {
		System.out.print("Post : ");
		postorder(root);
		System.out.println();
