		while(trav != null) {
			if (val == trav.data) 
				return new Node[] {
						trav,parent };
				parent = trav ;
				if(val < trav.data)
					trav = trav.left;
				else
					trav = trav.right;
				}
				return new Node[] { null , null } ;
			}
		
	void delete(int val) {
