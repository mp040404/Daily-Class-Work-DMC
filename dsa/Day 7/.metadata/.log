import java.util.Scanner;

public class BinSearchTree {
	
	static class Node{
		private int data ;
		private Node left ;
		private Node right;
		public Node(int data) {
			super();
			this.data = data;
			this.left = null;
			this.right = null;
		}
		public int getData() {
			return this.data = data;
		}
		
	}
	
