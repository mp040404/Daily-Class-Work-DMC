	private Node addRec()
	
	
	private void preorder(Node trav) {
		if(trav == null) 
			return ;
		System.out.print(trav.data + " , ");
		preorder(trav.left);
		preorder(trav.right);
	}
	
	public void preorder() {
		System.out.print("PRE : ");
		preorder(root);
		System.out.println();
	}
	
	public void inorder(Node trav) {
		if(trav == null)
			return ;
		inorder(trav.left);
		System.out.print(trav.data + " , ");
		inorder(trav.right);
	}
	
	public void inorder() {
		System.out.print("IN : ");
		inorder(root);
		System.out.println();
	}

	private void postorder(Node trav) {
		if(trav == null)
			return ;
		postorder(trav.left);
		postorder(trav.right);
		System.out.print(trav.data + " , ");
	}
	
	public void postorder() {
		System.out.print("Post : ");
		postorder(root);
		System.out.println();
	}
	
//	public Node search(int val) {
//		Node trav = root ;
//		while(trav != null) {
//			if(val == trav.data)
